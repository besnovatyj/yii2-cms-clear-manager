{
  "name": "besnovatyj/yii2-cms-clear-manager",
  "description": "Модуль для управления и очистки временных данных приложения",
  "type": "yii2-extension",
  "license": "MIT",
  "authors": [
    {
      "name": "Besnovatyj",
      "email": "your-email@example.com"
    }
  ],
  "minimum-stability": "stable",
  "extra": {
    "moduleClass": "Besnovatyj\\ClearManager\\Module",
    "moduleId": "ClearManager",
    "bescms": { "kind": "module" }
  },
  "keywords": [
    "yii2",
    "clear",
    "cache",
    "cleanup"
  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    },
    "fxp-asset": {
      "enabled": false
    }
  },
  "require": {
    "besnovatyj/yii2-cms-kernel": "^1.0",
    "besnovatyj/yii2-cms-contracts": "^1.0",
    "besnovatyj/yii2-cms-user": "^1.0",
    "ext-apcu": "*",
    "php": ">=8.4",
    "yiisoft/yii2": "~2.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Besnovatyj\\ClearManager\\": "src/"
    }
  }
}
